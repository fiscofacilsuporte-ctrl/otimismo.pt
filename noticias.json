  <div class="footer-bottom">
    &copy; 2026 otimismo.pt — Todos os direitos reservados. Feito com ❤️ em Portugal.
  </div>
</footer>

<script>
// ── CONFIGURAÇÕES E DATA SOURCE ──
// URL do JSON gerado pela Cloudflare Worker que faz o scraping e análise de sentimento
const JSON_URL = 'https://news-worker.p-macedo89.workers.dev/';

let allArticles = [];
let currentCategory = 'todas';
let displayLimit = 9;

document.addEventListener('DOMContentLoaded', () => {
  initMenu();
  initAmountButtons();
  fetchNews();

  document.getElementById('btnLoadMore').addEventListener('click', () => {
    displayLimit += 6;
    renderGrid();
  });
});

// ── DATA FETCHING ──
async function fetchNews() {
  try {
    const res = await fetch(JSON_URL);
    if (!res.ok) throw new Error('Falha na resposta da rede');
    const data = await res.json();
    
    // Suporta estrutura direta [] ou { articles: [], last_update: ... }
    if (Array.isArray(data)) {
      allArticles = data;
    } else if (data && data.articles) {
      allArticles = data.articles;
      if (data.last_update) {
        document.getElementById('lastUpdate').textContent = `• Atualizado: ${formatLastUpdate(data.last_update)}`;
      }
    }

    // Fallback caso venha vazio
    if(!allArticles || allArticles.length === 0) {
      generateMockData();
    }

    // Processamento e Renderização
    buildTicker();
    buildTrending();
    renderFeatured();
    renderGrid();

  } catch (err) {
    console.error('Erro ao ir buscar notícias reais, a usar fallback mock local:', err);
    generateMockData();
    buildTicker();
    buildTrending();
    renderFeatured();
    renderGrid();
  }
}

// ── RENDER FEATURED (A mais positiva do topo) ──
function renderFeatured() {
  const featContainer = document.getElementById('featuredSection');
  if (!featContainer) return;

  // Filtra artigos que tenham imagem ou títulos fortes e pontuação alta
  const validFeat = allArticles.filter(a => a.score >= 4);
  if (validFeat.length < 2) {
    // se não houver dados suficientes, limpa ou usa os primeiros
    featContainer.style.display = 'none';
    return;
  }

  const main = validFeat[0];
  const side1 = validFeat[1];
  const side2 = validFeat[2] || allArticles[3];

  let sideHtml = '';
  [side1, side2].forEach(item => {
    if(!item) return;
    sideHtml += `
      <a href="${item.link}" target="_blank" class="feat-card-sm">
        <div class="thumb">${getEmoji(item.category)}</div>
        <div class="info">
          <div class="cat-tag">${item.category || 'Geral'}</div>
          <h4 class="title-sm">${item.title}</h4>
          <div class="source-sm">${item.source} • ${item.time || 'Hoje'}</div>
        </div>
      </a>
    `;
  });

  featContainer.innerHTML = `
    <a href="${main.link}" target="_blank" class="featured-main">
      <div>
        <span class="feat-badge">Destaque Construtivo</span>
        <h3 class="feat-title">${main.title}</h3>
        <div class="feat-meta">
          <span>Fonte: ${main.source}</span>
          <span>•</span>
          <span class="feat-score">Índice de Otimismo: ${main.score}/5 ${getStars(main.score)}</span>
        </div>
      </div>
    </a>
    <div class="featured-side">
      ${sideHtml}
    </div>
  `;
}

// ── RENDER GRID ──
function renderGrid() {
  const grid = document.getElementById('newsGrid');
  if (!grid) return;

  // Filtrar por categoria
  let filtered = allArticles;
  if (currentCategory !== 'todas') {
    filtered = allArticles.filter(a => (a.category || '').toLowerCase() === currentCategory.toLowerCase());
  }

  // Se não houver nada após o filtro
  if (filtered.length === 0) {
    grid.innerHTML = `<div style="grid-column: 1/-1; text-align:center; padding:40px; color:var(--gray-600);">Sem notícias disponíveis nesta editoria de momento.</div>`;
    document.getElementById('btnLoadMore').style.display = 'none';
    return;
  }

  // Paginação simples
  const toRender = filtered.slice(0, displayLimit);
  
  grid.innerHTML = toRender.map(a => {
    const cleanCat = (a.category || 'geral').toLowerCase();
    const cleanSummary = a.summary || 'Clica na notícia para ler a cobertura completa e os impactos positivos diretamente no portal original.';
    return `
      <a href="${a.link}" target="_blank" class="news-card">
        <div class="thumb">${getEmoji(a.category)}</div>
        <div class="body">
          <div>
            <span class="cat-pill ${cleanCat}">${a.category || 'Geral'}</span>
          </div>
          <h3 class="card-title">${a.title}</h3>
          <p class="card-summary">${cleanSummary}</p>
          <div class="card-footer">
            <span class="card-source">${a.source}</span>
            <div class="card-score" title="Pontuação de Otimismo Baseada em IA">
              <span>${a.score || '4.2'}/5</span>
              <div class="score-dots">
                ${renderScoreDots(a.score)}
              </div>
            </div>
          </div>
        </div>
      </a>
    `;
  }).join('');

  // Mostrar ou esconder botão Ver Mais
  const btnMore = document.getElementById('btnLoadMore');
  if (filtered.length > displayLimit) {
    btnMore.style.display = 'inline-block';
  } else {
    btnMore.style.display = 'none';
  }
}

// ── FILTRAGEM VIA TABS ──
function filterCat(catName) {
  currentCategory = catName;
  displayLimit = 9;

  // Atualiza classe ativa nas tabs
  const tabs = document.querySelectorAll('.cat-tab');
  tabs.forEach(t => {
    if (t.getAttribute('data-cat') === catName) t.classList.add('active');
    else t.classList.remove('active');
  });

  // Atualiza título visual do feed
  const titleEl = document.getElementById('gridTitle');
  if(catName === 'todas') titleEl.textContent = "Feed de Notícias Inspiradoras";
  else titleEl.textContent = `Editoria: ${catName.charAt(0).toUpperCase() + catName.slice(1)}`;

  renderGrid();
}

// Vincula cliques às tabs superiores
document.getElementById('catTabs').addEventListener('click', (e) => {
  if (e.target.classList.contains('cat-tab')) {
    const cat = e.target.getAttribute('data-cat');
    filterCat(cat);
  }
});

// ── AUXILIARES DE RENDERIZAÇÃO ──
function renderScoreDots(score) {
  const val = Math.round(score || 4);
  let html = '';
  for (let i = 1; i <= 5; i++) {
    html += `<span class="score-dot ${i <= val ? 'filled' : ''}"></span>`;
  }
  return html;
}

function getEmoji(cat) {
  if (!cat) return '✨';
  switch (cat.toLowerCase()) {
    case 'ambiente': return '🌲';
    case 'saude': case 'saúde': return '❤️';
    case 'tecnologia': return '⚡';
    case 'economia': return '📈';
    case 'ciencia': case 'ciência': return '🔬';
    case 'sociedade': return '🤝';
    case 'desporto': return '🏆';
    default: return '✨';
  }
}

function getStars(score) {
  const count = Math.round(score || 4);
  return '★'.repeat(count) + '☆'.repeat(5 - count);
}

// ── CONSTRUÇÃO DO TICKER ──
function buildTicker() {
  const tickerContainer = document.getElementById('tickerText');
  if (!tickerContainer || allArticles.length === 0) return;

  // Junta os 6 primeiros títulos para fazer o scroll infinito
  const tickerItems = allArticles.slice(0, 6).map(a => `✦ ${a.title} (${a.source})`).join('     ');
  // Duplica para efeito de loop contínuo perfeito no CSS marquee
  tickerContainer.textContent = tickerItems + '     ' + tickerItems;
}

// ── CONSTRUÇÃO DO TRENDING SIDEBAR ──
function buildTrending() {
  const container = document.getElementById('trendingContainer');
  if (!container || allArticles.length === 0) return;

  // Seleciona do meio da lista para variar os artigos
  const trending = allArticles.slice(3, 7);
  container.innerHTML = trending.map((a, index) => `
    <a href="${a.link}" target="_blank" class="trending-item">
      <div class="trending-num">0${index + 1}</div>
      <div>
        <h4 class="trending-title">${a.title}</h4>
        <div class="trending-cat">${a.category || 'Geral'}</div>
      </div>
    </a>
  `).join('');
}

// ── INITIALIZADORES DE UI BASE ──
function initMenu() {
  const toggle = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  if (toggle && mobileMenu) {
    toggle.addEventListener('click', () => {
      const isShow = mobileMenu.style.display === 'block';
      mobileMenu.style.display = isShow ? 'none' : 'block';
      toggle.classList.toggle('active', !isShow);
    });
  }
}

function initAmountButtons() {
  const btns = document.querySelectorAll('.amount-amounts .amount-btn');
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
}

function showToast(msg) {
  let el = document.getElementById('toast');
  if(!el){
    el = document.createElement('div');
    el.id = 'toast';
    el.className = 'toast';
    document.body.appendChild(el);
  }
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(el._t);
  el._t = setTimeout(() => el.classList.remove('show'), 3800);
}

// ── PARSE DATA last_update (suporta DD/MM/AAAA HH:MM e ISO) ──
function formatLastUpdate(str) {
  if (!str) return '';
  // Formato português: "22/05/2026 16:32"
  const ptMatch = str.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})\s+(\d{1,2}):(\d{2})/);
  if (ptMatch) {
    const [,d,m,y,h,min] = ptMatch;
    return d+'/'+m+'/'+y+' às '+h+':'+min;
  }
  // Formato ISO: tenta converter
  try {
    const dt = new Date(str);
    if (!isNaN(dt)) {
      return dt.toLocaleDateString('pt-PT',{day:'2-digit',month:'short'})
        +' às '+dt.toLocaleTimeString('pt-PT',{hour:'2-digit',minute:'2-digit'});
    }
  } catch(e) {}
  return str; // fallback: mostra como está
}

// ── MOCK DATA / FALLBACK LOCAL ──
function generateMockData() {
  allArticles = [
    { title: "Cientistas portugueses desenvolvem terapia inovadora e revertem Alzheimer precoce em testes laboratoriais", source: "Público", link: "#", category: "Saúde", score: 4.9 },
    { title: "Reflorestação massiva na Serra da Estrela duplica biodiversidade local em apenas dois anos de monitorização", source: "Expresso", link: "#", category: "Ambiente", score: 4.8 },
    { title: "Empresa de Braga cria painéis solares flexíveis e ultra-transparentes para janelas habitacionais urbanas", source: "Jornal de Negócios", link: "#", category: "Tecnologia", score: 4.7 },
    { title: "Portugal bate recorde absoluto com 87% de energia consumida vinda de fontes totalmente renováveis nesta primavera", source: "Eco", link: "#", category: "Economia", score: 4.6 },
    { title: "Nova vacina universal contra a gripe testada com sucesso entra na fase final de aprovação europeia", source: "RTP Notícias", link: "#", category: "Saúde", score: 4.5 },
    { title: "Estudantes criam dispositivo de baixo custo que limpa microplásticos dos oceanos usando ondas sonoras focadas", source: "Techenet", link: "#", category: "Ciência", score: 4.4 },
    { title: "Bairros solidários: projeto social reduz isolamento de idosos em Lisboa em mais de sessenta por cento", source: "Observador", link: "#", category: "Sociedade", score: 4.3 },
    { title: "Seleção Nacional de Surf adaptado conquista medalha de ouro histórica no campeonato mundial em canárias", source: "A Bola", link: "#", category: "Desporto", score: 4.7 },
    { title: "Espécies de aves consideradas extintas há meio século voltam a nidificar ativamente nas margens do Douro", source: "Wilder", link: "#", category: "Ambiente", score: 4.2 }
  ];
}
</script>

