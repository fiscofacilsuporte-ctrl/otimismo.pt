</div>

<footer>
  <div class="footer-inner">
    <div class="footer-col">
      <div class="footer-brand">otimismo<span>.pt</span></div>
      <p class="footer-desc">Um portal dedicado ao jornalismo construtivo e de soluções. Acreditamos que mostrar o que corre bem inspira o mundo a ser melhor.</p>
    </div>
    <div class="footer-col">
      <h4>Editorias</h4>
      <a href="#" onclick="filterCat('ambiente');return false;">Ambiente</a>
      <a href="#" onclick="filterCat('saude');return false;">Saúde</a>
      <a href="#" onclick="filterCat('tecnologia');return false;">Tecnologia</a>
      <a href="#" onclick="filterCat('ciencia');return false;">Ciência</a>
    </div>
    <div class="footer-col">
      <h4>Projeto</h4>
      <a href="#">Sobre Nós</a>
      <a href="#">Estatuto Editorial</a>
      <a href="#">Código de Ética</a>
      <a href="#">Apoiar o Portal</a>
    </div>
    <div class="footer-col">
      <h4>Legal</h4>
      <a href="#">Termos de Uso</a>
      <a href="#">Política de Privacidade</a>
      <a href="#">Cookies</a>
    </div>
