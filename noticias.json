      <button class="btn-apoiar-main" onclick="showToast('Obrigado pelo teu interesse em apoiar! Sistema disponível brevemente.')">Apoiar Agora</button>
    </div>

    <div class="sidebar-card">
      <div class="sidebar-card-header">Injeção Semanal de Otimismo</div>
      <div class="sidebar-card-body">
        <p style="font-size:13px; color:var(--gray-600); margin-bottom:12px;">Subscreve para receberes todos os domingos o resumo das 7 melhores notícias da semana.</p>
        <form class="newsletter-form" onsubmit="event.preventDefault(); showToast('Subscrição efetuada! Bem-vindo ao lado positivo.'); this.reset();">
          <input type="email" placeholder="O teu e-mail principal" required>
          <button type="submit" class="btn-subscribe">Quero Subscrever</button>
        </form>
